generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organigramme ───

model Employee {
  id          String     @id @default(cuid())
  name        String
  initials    String
  role        String
  department  String
  location    String?
  email       String?
  phone       String?
  telegram    String?
  whatsapp    String?
  timezone    String?
  workHours   String?
  entity      String?
  country     String?
  startDate   DateTime?
  bio         String?    @db.Text
  avatarColor String
  managerId   String?
  manager     Employee?  @relation("Management", fields: [managerId], references: [id])
  reports     Employee[] @relation("Management")
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Tasks (Kanban) ───

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  tag         String
  priority    String    @default("medium")
  assignee    String?
  deadline    DateTime?
  column      String    @default("todo")
  order       Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Organigramme (Legal Structure) ───

model OrgEntity {
  id           String      @id @default(cuid())
  name         String
  jurisdiction String?
  type         String      @default("Operating Entity")
  parentId     String?
  parent       OrgEntity?  @relation("OrgStructure", fields: [parentId], references: [id])
  children     OrgEntity[] @relation("OrgStructure")
  order        Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// ─── Wiki ───

model WikiPage {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  content      Json
  category     String?
  icon         String?
  parentId     String?
  parent       WikiPage?     @relation("WikiHierarchy", fields: [parentId], references: [id])
  children     WikiPage[]    @relation("WikiHierarchy")
  pinned       Boolean       @default(false)
  archived     Boolean       @default(false)
  order        Int           @default(0)
  lastViewedBy String?
  viewCount    Int           @default(0)
  createdBy    String
  updatedBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  versions     WikiVersion[]
}

model WikiVersion {
  id        String   @id @default(cuid())
  pageId    String
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  content   Json
  editedBy  String
  createdAt DateTime @default(now())
}

// ─── Calendar ───

model CalendarEvent {
  id            String    @id @default(cuid())
  googleEventId String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  attendees     String[]
  calendarOwner String
  location      String?
  meetLink      String?
  callNote      CallNote?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([googleEventId, calendarOwner])
}

// ─── Call Notes ───

model CallNote {
  id          String         @id @default(cuid())
  title       String
  date        DateTime
  htmlContent String         @db.Text
  noteData    Json?
  eventId     String?        @unique
  event       CalendarEvent? @relation(fields: [eventId], references: [id])
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── Dashboard / KPIs ───

model KpiEntry {
  id        String   @id @default(cuid())
  metric    String
  value     Float
  date      DateTime
  entity    String   @default("oxen")
  createdBy String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String
  userId    String
  createdAt DateTime @default(now())
}

// ─── CRM / CRO Revenue Intelligence ───

model Contact {
  id              String            @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  sector          String?
  status          String            @default("lead")
  source          String?
  value           Float?
  currency        String            @default("EUR")
  notes           String?           @db.Text
  assignedTo      String?
  telegram        String?
  whatsapp        String?
  website         String?
  country         String?
  // CRO fields
  healthStatus    String            @default("healthy")
  monthlyGtv      Float?
  monthlyRevenue  Float?
  takeRate        Float?
  segment         String?
  projectedVolume Float?
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  interactions    Interaction[]
  metrics         CustomerMetrics[]
  deals           Deal[]
  supportTickets  SupportTicket[]
  companyIntel    CompanyIntel[]    @relation("ContactIntel")
  meetingBriefs   MeetingBrief[]   @relation("ContactBriefs")
  aiInsights      AIInsight[]      @relation("ContactInsights")
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String
  content   String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
}

model CustomerMetrics {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  month     String   // "YYYY-MM"
  gtv       Float    @default(0)
  revenue   Float    @default(0)
  takeRate  Float    @default(0)
  txCount   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, month])
}

model Deal {
  id              String   @id @default(cuid())
  name            String
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stage           String   @default("discovery")
  expectedVolume  Float?
  takeRate        Float?
  expectedRevenue Float?
  probability     Float    @default(50)
  closeDate       DateTime?
  assignedTo      String?
  notes           String?  @db.Text
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Finance ───

model FinanceEntry {
  id          String   @id @default(cuid())
  type        String   // "revenue", "expense", "budget"
  category    String
  description String?
  amount      Float
  currency    String   @default("EUR")
  date        DateTime
  entity      String   @default("oxen")
  recurring   Boolean  @default(false)
  notes       String?  @db.Text
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinanceGoal {
  id        String   @id @default(cuid())
  metric    String   // "monthly_revenue", "monthly_expense", "profit_margin", "runway_months"
  target    Float
  entity    String   @default("oxen")
  period    String   // "2026-Q1", "2026-03", etc.
  createdBy String
  createdAt DateTime @default(now())
}

// ─── Marketing ───

model SocialMetrics {
  id          String   @id @default(cuid())
  platform    String   // "linkedin", "twitter", "telegram", "instagram", "youtube", "tiktok"
  date        DateTime
  followers   Int      @default(0)
  impressions Int      @default(0)
  engagement  Int      @default(0)
  clicks      Int      @default(0)
  posts       Int      @default(0)
  entity      String   @default("oxen")
  createdBy   String
  createdAt   DateTime @default(now())

  @@unique([platform, date, entity])
}

model ContentIdea {
  id           String    @id @default(cuid())
  title        String
  description  String?   @db.Text
  platform     String?
  type         String?
  status       String    @default("idea")
  priority     String    @default("medium")
  scheduledFor DateTime?
  publishedAt  DateTime?
  assignedTo   String?
  tags         String[]
  notes        String?   @db.Text
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model MarketingIntel {
  id        String   @id @default(cuid())
  type      String   // "competitor", "trend", "tool", "regulation", "opportunity"
  title     String
  source    String?
  summary   String   @db.Text
  relevance String   @default("medium")
  tags      String[]
  createdBy String
  createdAt DateTime @default(now())
}

// ─── Support Module ───

model SupportTicket {
  id              String           @id @default(cuid())
  subject         String
  clientName      String
  clientEmail     String?
  channel         String           // "telegram", "email", "whatsapp", "phone", "live_chat"
  status          String           @default("open")       // "open", "in_progress", "waiting_client", "resolved", "closed"
  priority        String           @default("medium")     // "urgent", "high", "medium", "low"
  category        String?          // "account_issue", "transaction", "onboarding", "compliance", "technical", "general"
  assignedTo      String?
  contactId       String?
  contact         Contact?         @relation(fields: [contactId], references: [id])
  messages        SupportMessage[]
  resolvedAt      DateTime?
  firstResponseAt DateTime?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender     String        // "client" or employee name
  content    String        @db.Text
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
}

// ─── AI Sales Intelligence Module ───

model CompanyIntel {
  id             String    @id @default(cuid())
  contactId      String
  contact        Contact   @relation("ContactIntel", fields: [contactId], references: [id], onDelete: Cascade)
  companyName    String
  website        String?
  description    String?   @db.Text
  industry       String?
  employeeCount  String?
  revenue        String?
  headquarters   String?
  keyPeople      Json?     // [{name, title, linkedin, email}]
  recentNews     Json?     // [{title, source, url, date, summary, sentiment}]
  ownership      Json?
  creditRating   String?
  lastResearched DateTime?
  dataSource     String?   // "claude", "manual", "apollo", "clearbit"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MeetingBrief {
  id           String    @id @default(cuid())
  eventId      String?   @unique
  contactId    String?
  contact      Contact?  @relation("ContactBriefs", fields: [contactId], references: [id])
  title        String
  meetingDate  DateTime
  attendees    String[]
  briefContent Json      // {company_context, relationship_history, recent_news, deal_status, talking_points, risks, opportunities, suggested_ask}
  status       String    @default("generated")
  sentVia      String?
  createdBy    String    @default("ai")
  createdAt    DateTime  @default(now())
}

model AIInsight {
  id           String   @id @default(cuid())
  type         String   // "opportunity", "risk", "buying_signal", "churn_warning", "upsell", "news_alert", "follow_up_needed", "deal_stuck"
  title        String
  summary      String   @db.Text
  contactId    String?
  contact      Contact? @relation("ContactInsights", fields: [contactId], references: [id])
  severity     String   @default("medium")
  actionable   Boolean  @default(true)
  dismissed    Boolean  @default(false)
  actionTaken  String?
  linkedTaskId String?
  createdAt    DateTime @default(now())
}

model AIConversation {
  id        String   @id @default(cuid())
  messages  Json     // [{role, content, timestamp}]
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
