generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organigramme ───

model Employee {
  id          String     @id @default(cuid())
  name        String
  initials    String
  role        String
  department  String
  location    String?
  email       String?
  phone       String?
  telegram       String?
  telegramChatId String?
  whatsapp       String?
  timezone    String?
  workHours   String?
  entity      String?
  entityId    String?
  orgEntity   OrgEntity? @relation(fields: [entityId], references: [id])
  country     String?
  startDate   DateTime?
  bio         String?    @db.Text
  avatarColor String
  icon        String?
  managerId   String?
  manager     Employee?  @relation("Management", fields: [managerId], references: [id])
  reports     Employee[] @relation("Management")
  order       Int        @default(0)
  isAdmin     Boolean    @default(false)
  roleLevel   String     @default("member") // super_admin, admin, manager, member
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  leaveRequests   LeaveRequest[]  @relation("EmployeeLeaveRequests")
  reviewedLeaves  LeaveRequest[]  @relation("ReviewerLeaveRequests")
  leaveBalances   LeaveBalance[]
}

// ─── Tasks (Kanban) ───

model Task {
  id               String         @id @default(cuid())
  title            String
  description      String?
  tag              String
  priority         String         @default("medium")
  assignee         String?
  deadline         DateTime?
  column           String         @default("todo")
  order            Int            @default(0)
  supportTicketId  String?
  supportTicket    SupportTicket? @relation(fields: [supportTicketId], references: [id])
  contactId        String?
  contact          Contact?       @relation(fields: [contactId], references: [id])
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ─── Organigramme (Legal Structure) ───

model OrgEntity {
  id           String      @id @default(cuid())
  name         String
  jurisdiction String?
  type         String      @default("Operating Entity")
  parentId     String?
  parent       OrgEntity?  @relation("OrgStructure", fields: [parentId], references: [id])
  children     OrgEntity[] @relation("OrgStructure")
  employees    Employee[]
  driveLinks   DriveLink[]
  order        Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// ─── Wiki ───

model WikiPage {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  content      Json
  category     String?
  icon         String?
  parentId     String?
  parent       WikiPage?     @relation("WikiHierarchy", fields: [parentId], references: [id])
  children     WikiPage[]    @relation("WikiHierarchy")
  pinned       Boolean       @default(false)
  archived     Boolean       @default(false)
  order        Int           @default(0)
  lastViewedBy String?
  viewCount    Int           @default(0)
  createdBy    String
  updatedBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  versions     WikiVersion[]
  driveLinks   DriveLink[]
}

model WikiVersion {
  id        String   @id @default(cuid())
  pageId    String
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  content   Json
  editedBy  String
  createdAt DateTime @default(now())
}

// ─── Calendar ───

model CalendarEvent {
  id            String    @id @default(cuid())
  googleEventId String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  attendees     String[]
  calendarOwner String
  location      String?
  meetLink      String?
  callNote      CallNote?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([googleEventId, calendarOwner])
}

// ─── Internal Events (user-created meetings) ───

model InternalEvent {
  id             String    @id @default(cuid())
  title          String
  description    String?   @db.Text
  startTime      DateTime
  endTime        DateTime
  location       String?
  meetLink       String?
  attendees      String[]
  color          String?
  type           String    @default("meeting")
  recurring      String?
  recurringUntil DateTime?
  googleEventId  String?
  createdBy      String
  callNote       CallNote?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Call Notes ───

model CallNote {
  id              String          @id @default(cuid())
  title           String
  date            DateTime
  htmlContent     String          @db.Text
  noteData        Json?
  eventId         String?         @unique
  event           CalendarEvent?  @relation(fields: [eventId], references: [id])
  internalEventId String?         @unique
  internalEvent   InternalEvent?  @relation(fields: [internalEventId], references: [id])
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ─── Dashboard / KPIs ───

model KpiEntry {
  id        String   @id @default(cuid())
  metric    String
  value     Float
  date      DateTime
  entity    String   @default("oxen")
  createdBy String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String
  userId    String
  entityId  String?
  link      String?
  createdAt DateTime @default(now())
}

// ─── CRM / CRO Revenue Intelligence ───

model Contact {
  id              String            @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  sector          String?
  status          String            @default("lead")
  source          String?
  value           Float?
  currency        String            @default("EUR")
  notes           String?           @db.Text
  assignedTo      String?
  telegram        String?
  whatsapp        String?
  website         String?
  country         String?
  // CRO fields
  healthStatus    String            @default("healthy")
  monthlyGtv      Float?
  monthlyRevenue  Float?
  takeRate        Float?
  segment         String?
  projectedVolume Float?
  // GTM fields
  clientType        String?
  vertical          String?
  icpScore          Int?              @default(0)
  intentScore       Int?              @default(0)
  priorityScore     Int?              @default(0)
  leadSource        String?
  outreachStatus    String?           @default("new")
  lemlistCampaignId String?
  lastContactedAt   DateTime?
  lastRepliedAt     DateTime?
  agentId           String?
  agent             Agent?            @relation(fields: [agentId], references: [id])
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  interactions    Interaction[]
  metrics         CustomerMetrics[]
  deals           Deal[]
  supportTickets  SupportTicket[]
  companyIntel    CompanyIntel[]    @relation("ContactIntel")
  meetingBriefs   MeetingBrief[]   @relation("ContactBriefs")
  aiInsights      AIInsight[]      @relation("ContactInsights")
  emails          Email[]          @relation("ContactEmails")
  signals         IntentSignal[]
  outreachSequences OutreachSequence[]
  tasks           Task[]
  driveLinks      DriveLink[]       @relation("ContactDriveLinks")
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String
  content   String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
}

model CustomerMetrics {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  month     String   // "YYYY-MM"
  gtv       Float    @default(0)
  revenue   Float    @default(0)
  takeRate  Float    @default(0)
  txCount   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, month])
}

model Deal {
  id              String   @id @default(cuid())
  name            String
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stage           String   @default("discovery")
  expectedVolume  Float?
  takeRate        Float?
  expectedRevenue Float?
  probability     Float    @default(50)
  closeDate       DateTime?
  assignedTo      String?
  notes           String?  @db.Text
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Finance ───

model FinanceEntry {
  id          String   @id @default(cuid())
  type        String   // "revenue", "expense", "budget"
  category    String
  description String?
  amount      Float
  currency    String   @default("EUR")
  date        DateTime
  entity      String   @default("oxen")
  recurring   Boolean  @default(false)
  notes       String?  @db.Text
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinanceGoal {
  id        String   @id @default(cuid())
  metric    String   // "monthly_revenue", "monthly_expense", "profit_margin", "runway_months"
  target    Float
  entity    String   @default("oxen")
  period    String   // "2026-Q1", "2026-03", etc.
  createdBy String
  createdAt DateTime @default(now())
}

// ─── Marketing ───

model SocialMetrics {
  id          String   @id @default(cuid())
  platform    String   // "linkedin", "twitter", "telegram", "instagram", "youtube", "tiktok"
  date        DateTime
  followers   Int      @default(0)
  impressions Int      @default(0)
  engagement  Int      @default(0)
  clicks      Int      @default(0)
  posts       Int      @default(0)
  entity      String   @default("oxen")
  createdBy   String
  createdAt   DateTime @default(now())

  @@unique([platform, date, entity])
}

model ContentIdea {
  id           String    @id @default(cuid())
  title        String
  description  String?   @db.Text
  platform     String?
  type         String?
  status       String    @default("idea")
  priority     String    @default("medium")
  scheduledFor DateTime?
  publishedAt  DateTime?
  assignedTo   String?
  tags         String[]
  notes        String?   @db.Text
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model MarketingIntel {
  id        String   @id @default(cuid())
  type      String   // "competitor", "trend", "tool", "regulation", "opportunity"
  title     String
  source    String?
  summary   String   @db.Text
  relevance String   @default("medium")
  tags      String[]
  createdBy String
  createdAt DateTime @default(now())
}

// ─── Support Module ───

model SupportTicket {
  id              String           @id @default(cuid())
  subject         String
  clientName      String
  clientEmail     String?
  channel         String           // "telegram", "email", "whatsapp", "phone", "live_chat"
  status          String           @default("open")       // "open", "in_progress", "waiting_client", "resolved", "closed"
  priority        String           @default("medium")     // "urgent", "high", "medium", "low"
  category        String?          // "account_issue", "transaction", "onboarding", "compliance", "technical", "general"
  assignedTo      String?
  contactId       String?
  contact         Contact?         @relation(fields: [contactId], references: [id])
  messages        SupportMessage[]
  tasks           Task[]
  resolvedAt      DateTime?
  firstResponseAt DateTime?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender     String        // "client" or employee name
  content    String        @db.Text
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
}

// ─── AI Sales Intelligence Module ───

model CompanyIntel {
  id             String    @id @default(cuid())
  contactId      String
  contact        Contact   @relation("ContactIntel", fields: [contactId], references: [id], onDelete: Cascade)
  companyName    String
  website        String?
  description    String?   @db.Text
  industry       String?
  employeeCount  String?
  revenue        String?
  headquarters   String?
  keyPeople      Json?     // [{name, title, linkedin, email}]
  recentNews     Json?     // [{title, source, url, date, summary, sentiment}]
  ownership      Json?
  creditRating   String?
  lastResearched DateTime?
  dataSource     String?   // "claude", "manual", "apollo", "clearbit"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MeetingBrief {
  id           String    @id @default(cuid())
  eventId      String?   @unique
  contactId    String?
  contact      Contact?  @relation("ContactBriefs", fields: [contactId], references: [id])
  title        String
  meetingDate  DateTime
  attendees    String[]
  briefContent Json      // {company_context, relationship_history, recent_news, deal_status, talking_points, risks, opportunities, suggested_ask}
  status       String    @default("generated")
  sentVia      String?
  createdBy    String    @default("ai")
  createdAt    DateTime  @default(now())
}

model AIInsight {
  id           String   @id @default(cuid())
  type         String   // "opportunity", "risk", "buying_signal", "churn_warning", "upsell", "news_alert", "follow_up_needed", "deal_stuck"
  title        String
  summary      String   @db.Text
  contactId    String?
  contact      Contact? @relation("ContactInsights", fields: [contactId], references: [id])
  severity     String   @default("medium")
  actionable   Boolean  @default(true)
  dismissed    Boolean  @default(false)
  actionTaken  String?
  linkedTaskId String?
  source       String?  // "auto_analysis", "deal_stage_change", "system"
  createdAt    DateTime @default(now())
}

model AIConversation {
  id        String   @id @default(cuid())
  messages  Json     // [{role, content, timestamp}]
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Leave / Absence Management ───

model LeaveRequest {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  type          String    // "vacation" | "sick" | "ooo"
  startDate     DateTime
  endDate       DateTime
  halfDay       Boolean   @default(false)
  halfDayPeriod String?   // "morning" | "afternoon"
  reason        String?   @db.Text
  status        String    @default("pending") // "pending" | "approved" | "rejected"
  reviewedById  String?
  reviewedBy    Employee? @relation("ReviewerLeaveRequests", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?   @db.Text
  totalDays     Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LeaveBalance {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year            Int
  vacationTotal   Int      @default(25)
  vacationUsed    Float    @default(0)
  vacationPending Float    @default(0)
  sickTotal       Int      @default(10)
  sickUsed        Float    @default(0)
  oooTotal        Int      @default(15)
  oooUsed         Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, year])
}

model LeaveRules {
  id                   String   @id @default(cuid())
  generalPolicy        String?  @db.Text
  vacationQuota        Int      @default(25)
  vacationMinNotice    Int      @default(14)
  vacationMaxConsecutive Int    @default(15)
  vacationCarryOver    Int      @default(5)
  sickQuota            Int      @default(10)
  sickCertAfterDays    Int      @default(3)
  oooQuota             Int      @default(15)
  oooMinNotice         Int      @default(3)
  oooReasonRequired    Boolean  @default(true)
  approvalTimeline     Int      @default(2)
  blackoutPeriods      Json?
  updatedBy            String?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}

// ─── Email Sync ───

model Email {
  id            String   @id @default(cuid())
  contactId     String?
  contact       Contact? @relation("ContactEmails", fields: [contactId], references: [id])
  gmailId       String   @unique
  threadId      String?
  from          String
  to            String[]
  cc            String[]
  subject       String
  snippet       String?
  bodyText      String?  @db.Text
  date          DateTime
  labelIds      String[]
  hasAttachment Boolean  @default(false)
  direction     String   @default("inbound")
  syncedBy      String
  createdAt     DateTime @default(now())
}

// ─── Agent / Referral Partner ───

model Agent {
  id                  String    @id @default(cuid())
  name                String
  company             String?
  type                String    @default("broker")
  email               String?
  phone               String?
  telegram            String?
  whatsapp            String?
  country             String?
  website             String?
  commissionDirect    Float     @default(15)
  commissionIndirect  Float     @default(5)
  status              String    @default("prospect")
  onboardedAt         DateTime?
  notes               String?   @db.Text
  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  referredClients     Contact[]
  driveLinks          DriveLink[]
}

// ─── Intent Signals ───

model IntentSignal {
  id          String    @id @default(cuid())
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  source      String
  signalType  String
  title       String
  detail      String?   @db.Text
  score       Int       @default(0)
  expiresAt   DateTime?
  raw         Json?
  createdAt   DateTime  @default(now())
}

// ─── Outreach Sequences ───

model OutreachSequence {
  id              String   @id @default(cuid())
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  platform        String
  campaignName    String?
  status          String   @default("active")
  stepsCompleted  Int      @default(0)
  totalSteps      Int      @default(0)
  lastStepAt      DateTime?
  enqueuedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Intelligence Hub ───

model IntelResearch {
  id            String        @id @default(cuid())
  title         String
  category      String        // "marketing", "ai_tools", "competitors", "regulations", "conferences", "oxen", "finance"
  subcategory   String?
  query         String?       @db.Text
  sources       String[]      // ["linkedin", "twitter", "reddit", "github", etc.]
  keywords      String[]      // search keywords
  companies     String[]      // companies to monitor
  regions       String[]      // geographic focus
  language      String        @default("english")
  type          String        // "one_time" or "recurring"
  frequency     String?       // "daily", "weekly", "biweekly", "monthly"
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  status        String        @default("active") // "active", "paused", "completed"
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  results       IntelResult[]
}

model IntelResult {
  id            String        @id @default(cuid())
  researchId    String
  research      IntelResearch @relation(fields: [researchId], references: [id], onDelete: Cascade)
  title         String
  summary       String        @db.Text
  source        String?
  sourceType    String?       // "linkedin", "twitter", "reddit", "github", "google", "news", "website", "review_site", "regulatory", "conference_site"
  sentiment     String?       // "positive", "negative", "neutral"
  relevance     String        @default("medium") // "critical", "high", "medium", "low"
  actionable    Boolean       @default(false)
  read          Boolean       @default(false)
  starred       Boolean       @default(false)
  metadata      Json?
  createdAt     DateTime      @default(now())
}

// ─── Drive Links (Google Drive integration) ───

model DriveLink {
  id          String     @id @default(cuid())
  driveFileId String
  fileName    String
  fileUrl     String     // webViewLink to open in Drive
  mimeType    String
  iconUrl     String?
  category    String?    // "contract", "kyc", "invoice", "proposal", "legal", "compliance", "process", "other"
  contactId   String?
  contact     Contact?   @relation("ContactDriveLinks", fields: [contactId], references: [id])
  agentId     String?
  agent       Agent?     @relation(fields: [agentId], references: [id])
  wikiPageId  String?
  wikiPage    WikiPage?  @relation(fields: [wikiPageId], references: [id])
  entityId    String?
  entity      OrgEntity? @relation(fields: [entityId], references: [id])
  createdBy   String
  createdAt   DateTime   @default(now())
}
