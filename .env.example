# ─────────────────────────────────────────────────────────────────────
# Oxen OS — Environment variables
#
# Copy this file to `.env.local` and fill in the values below.
# NEVER commit `.env.local` or any file containing real secrets.
#
# Markers:
#   [REQUIRED]  Must be set for the app to start / function
#   [OPTIONAL]  Has a sane default, override only if needed
#   [PROD]      Only relevant in production (Railway), optional in local dev
#   [SHARED]    Needed by both the Next.js monolith AND the sync-worker
# ─────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════
# DATABASE
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] [SHARED] PostgreSQL connection string
# Dev  : local Postgres (docker or Postgres.app)
# Prod : provided automatically by Railway
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oxen_os_dev"


# ═════════════════════════════════════════════════════════════════════
# NEXTAUTH v5 / Auth.js
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] URL where the app runs. In prod: https://os.oxen.finance
NEXTAUTH_URL="http://localhost:3000"

# [REQUIRED] Random secret for signing session JWTs.
# Auth.js v5 also accepts the legacy name NEXTAUTH_SECRET as a fallback
# (see src/lib/auth.ts). We use AUTH_SECRET here — do NOT set both.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""


# ═════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH (Gmail + Calendar + Drive)
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] OAuth 2.0 credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Required scopes: openid email profile
#                  https://www.googleapis.com/auth/calendar
#                  https://www.googleapis.com/auth/gmail.readonly
#                  https://www.googleapis.com/auth/drive.readonly
# Sign-in is restricted to @oxen.finance email addresses
# (enforced in src/lib/auth.ts signIn callback).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ═════════════════════════════════════════════════════════════════════
# TOKEN ENCRYPTION (Sprint 1.3 — AES-256-GCM at rest)
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] [SHARED] AES-256 key (32 bytes in base64) used to encrypt
# OAuth tokens stored in the Account table. Versioned format in DB:
# enc:v1:<iv>:<ciphertext>:<authtag>
#
# Generate with: openssl rand -base64 32
#
# ⚠️ CRITICAL
# - MUST be backed up (e.g. 1Password) BEFORE pasting into Railway.
#   Railway does not allow re-reading a variable after save.
# - Losing the key makes all stored OAuth tokens unrecoverable; every
#   user must re-authenticate against Google.
# - MUST be identical on both Railway services: oxen-os AND sync-worker.
#   Divergence causes silent decryption failures.
TOKEN_ENCRYPTION_KEY_V1=""


# ═════════════════════════════════════════════════════════════════════
# TELEGRAM BOT (@Oxen_deal_info_bot)
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] Bot token from @BotFather
TELEGRAM_BOT_TOKEN=""

# [REQUIRED] [PROD] Webhook URL passed to setWebhook
# Dev: can be omitted when using getUpdates polling
TELEGRAM_WEBHOOK_URL="https://os.oxen.finance/api/telegram/webhook"

# [REQUIRED] Secret passed to setWebhook via the `secret_token` parameter.
# Telegram echoes it in the `X-Telegram-Bot-Api-Secret-Token` header on
# every incoming update; the handler verifies it via timingSafeEqual.
# Must match [A-Za-z0-9_-]{1,256}.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=""

# [OPTIONAL] Chat ID to receive automatic SEO article notifications
TELEGRAM_SEO_CHAT_ID=""


# ═════════════════════════════════════════════════════════════════════
# LEMLIST (outbound email)
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] Lemlist API key (used with HTTP Basic Auth for outbound calls)
LEMLIST_API_KEY=""

# [REQUIRED] HMAC secret used to verify incoming Lemlist webhook signatures.
# Configure the identical value in Lemlist dashboard → Webhooks.
LEMLIST_WEBHOOK_SECRET=""


# ═════════════════════════════════════════════════════════════════════
# WEBHOOK SECRETS (shared-secret auth via requireWebhookSecret helper)
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] Shared secret for Clay intent-signal webhook
# Passed by Clay in the `x-webhook-secret` header.
CLAY_WEBHOOK_SECRET=""

# [REQUIRED] Shared secrets for Trigify and N8N automation webhooks
TRIGIFY_WEBHOOK_SECRET=""
N8N_WEBHOOK_SECRET=""

# [REQUIRED] Shared secret for the public Oxen Finance website contact form.
# Configure the identical value in the website's webhook settings.
WEBSITE_WEBHOOK_SECRET=""

# [REQUIRED] Shared secret for the support inbound webhook
SUPPORT_WEBHOOK_SECRET=""


# ═════════════════════════════════════════════════════════════════════
# ANTHROPIC CLAUDE
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] [SHARED] API key from https://console.anthropic.com
# Used by in-app AI features AND by the ai-worker (Sentinel, scoring…)
ANTHROPIC_API_KEY=""


# ═════════════════════════════════════════════════════════════════════
# INTERNAL / CRON / APP URL
# ═════════════════════════════════════════════════════════════════════

# [REQUIRED] Shared secret authenticating internal cron calls
# (e.g. Lemlist sync scheduled job hitting an internal endpoint).
CRON_SECRET=""

# [OPTIONAL] Public URL of the app, readable client-side (Next.js prefix).
# Used to generate absolute links in AI follow-up UI.
# Defaults to NEXTAUTH_URL when unset.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# [OPTIONAL] App URL used by the sync-worker to call back into the monolith
# (e.g. scheduled endpoints). Falls back to NEXTAUTH_URL, then to
# https://os.oxen.finance if neither is set.
APP_URL="http://localhost:3000"


# ═════════════════════════════════════════════════════════════════════
# WORKERS (sync-worker + ai-worker)
# ═════════════════════════════════════════════════════════════════════

# [OPTIONAL] Toggle background workers. Set to "false" in local dev if you
# don't want Claude API calls / Google sync jobs running locally.
ENABLE_WORKERS="true"

# [OPTIONAL] ai-worker polling interval in ms (default: 5000)
AI_POLL_INTERVAL_MS="5000"

# [OPTIONAL] sync-worker polling interval in ms (default: 10000)
SYNC_POLL_INTERVAL_MS="10000"

# [OPTIONAL] Timeout in ms after which a job stuck in `processing` is
# reclaimed by another worker instance (default: 300000 = 5 min).
STALE_JOB_TIMEOUT_MS="300000"
