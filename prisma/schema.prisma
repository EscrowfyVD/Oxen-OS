generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organigramme ───

model Employee {
  id          String     @id @default(cuid())
  name        String
  initials    String
  role        String
  department  String
  location    String?
  email       String?
  phone       String?
  telegram    String?
  whatsapp    String?
  timezone    String?
  workHours   String?
  entity      String?
  avatarColor String
  managerId   String?
  manager     Employee?  @relation("Management", fields: [managerId], references: [id])
  reports     Employee[] @relation("Management")
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Tasks (Kanban) ───

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  tag         String
  priority    String    @default("medium")
  assignee    String?
  deadline    DateTime?
  column      String    @default("todo")
  order       Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Organigramme (Legal Structure) ───

model OrgEntity {
  id           String      @id @default(cuid())
  name         String
  jurisdiction String?
  type         String      @default("Operating Entity")
  parentId     String?
  parent       OrgEntity?  @relation("OrgStructure", fields: [parentId], references: [id])
  children     OrgEntity[] @relation("OrgStructure")
  order        Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// ─── Wiki ───

model WikiPage {
  id        String        @id @default(cuid())
  title     String
  slug      String        @unique
  content   Json
  category  String?
  createdBy String
  updatedBy String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  versions  WikiVersion[]
}

model WikiVersion {
  id        String   @id @default(cuid())
  pageId    String
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  content   Json
  editedBy  String
  createdAt DateTime @default(now())
}

// ─── Calendar ───

model CalendarEvent {
  id            String    @id @default(cuid())
  googleEventId String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  attendees     String[]
  calendarOwner String
  location      String?
  meetLink      String?
  callNote      CallNote?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([googleEventId, calendarOwner])
}

// ─── Call Notes ───

model CallNote {
  id          String         @id @default(cuid())
  title       String
  date        DateTime
  htmlContent String         @db.Text
  noteData    Json?
  eventId     String?        @unique
  event       CalendarEvent? @relation(fields: [eventId], references: [id])
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── Dashboard / KPIs ───

model KpiEntry {
  id        String   @id @default(cuid())
  metric    String
  value     Float
  date      DateTime
  entity    String   @default("oxen")
  createdBy String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String
  userId    String
  createdAt DateTime @default(now())
}

// ─── CRM ───

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  sector       String?
  status       String        @default("lead")
  source       String?
  value        Float?
  currency     String        @default("EUR")
  notes        String?       @db.Text
  assignedTo   String?
  telegram     String?
  whatsapp     String?
  website      String?
  country      String?
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String
  content   String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
}
